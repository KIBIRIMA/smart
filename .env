# ─────────────────────────────────────────────
# Smart Transport AI — configuration
# Copiez ce fichier en .env et adaptez les valeurs.
# ─────────────────────────────────────────────

APP_ENV=production
DEBUG=false

# ⚠️ Générez une clé forte : openssl rand -hex 32
SECRET_KEY=HKc2026.!
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Base de données
POSTGRES_USER=smarttransport
POSTGRES_PASSWORD=HKc2026.!
POSTGRES_DB=smarttransport
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# CORS — domaine du frontend en production
CORS_ORIGINS=["https://smart-transport.fr","http://localhost:3000"]

# Workers uvicorn
WORKERS=2
